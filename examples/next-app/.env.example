# Server-side: never expose to the client. Used by middleware.
CUPED_DSN=https://YOUR_KEY@api.cuped.io
CUPED_COOKIE_SECRET=run-`openssl rand -base64 32`-and-paste-the-result

# Client-side: same DSN, exposed to the browser bundle for the React provider.
NEXT_PUBLIC_CUPED_DSN=https://YOUR_KEY@api.cuped.io

# Optional: experiment id to demonstrate. Should be a draft+running experiment in your project.
NEXT_PUBLIC_CUPED_EXPERIMENT_ID=00000000-0000-0000-0000-000000000000
