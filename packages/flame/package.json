{
  "name": "@cuped-io/flame",
  "version": "0.2.1",
  "description": "Client-side A/B testing SDK for cuped.io",
  "license": "MIT",
  "author": "Mike Ross <michael.s.ross@protonmail.com>",
  "homepage": "https://cuped.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuped-io/flame.git",
    "directory": "packages/flame"
  },
  "bugs": {
    "url": "https://github.com/cuped-io/flame/issues"
  },
  "keywords": [
    "ab-testing",
    "experimentation",
    "cuped",
    "feature-flags",
    "analytics"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./iife": "./dist/flame.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && vite build --config vite.config.npm.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.17",
    "jsdom": "^27.4.0",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
