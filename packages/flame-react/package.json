{
  "name": "@cuped-io/flame-react",
  "version": "0.1.0",
  "description": "React bindings for the cuped.io A/B testing SDK (@cuped-io/flame)",
  "license": "MIT",
  "author": "Mike Ross <michael.s.ross@protonmail.com>",
  "homepage": "https://cuped.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cuped-io/flame.git",
    "directory": "packages/flame-react"
  },
  "bugs": {
    "url": "https://github.com/cuped-io/flame/issues"
  },
  "keywords": [
    "ab-testing",
    "experimentation",
    "cuped",
    "react",
    "feature-flags"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cuped-io/flame": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^27.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
